<?xml version="1.0"?>
<!--
/**
 * ACL resources for AI Product Description.
 *
 * Defines permissions for configuration and product description generation.
 *
 * @category  Mnaeem
 * @package   Mnaeem_AiProductDescription
 */
-->
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:Acl/etc/acl.xsd">
    <acl>
        <resources>
            <resource id="Magento_Backend::admin">
                <resource id="Magento_Catalog::catalog">
                    <resource id="Magento_Catalog::catalog_products" title="Products">
                        <resource id="Mnaeem_AiProductDescription::generate" title="Generate AI Description"/>
                    </resource>
                </resource>
                <resource id="Magento_Backend::stores">
                    <resource id="Magento_Backend::stores_settings">
                        <resource id="Magento_Config::config">
                            <resource id="Mnaeem_AiProductDescription::config" title="AI Product Description Config"/>
                        </resource>
                    </resource>
                </resource>
            </resource>
        </resources>
    </acl>
</config>
